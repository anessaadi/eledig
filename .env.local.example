# Copy this file to .env.local and fill in your values.

# Admin password (used to log into /fr/admin or /ar/admin)
ADMIN_PASSWORD=change-me-please

# A long random secret used to sign the admin session cookie
ADMIN_SECRET=replace-with-a-long-random-string

# Secret the cron job must send to delete expired invitations
CRON_SECRET=another-long-random-string

# Your public site URL (used to build the invitation links)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Your WhatsApp number in international format, digits only (e.g. 213xxxxxxxxx)
NEXT_PUBLIC_WHATSAPP=213000000000
